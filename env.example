# ============================================
# PST — Pure Smart Telecom
# Variables d'environnement (.env)
# ============================================
# Copier ce fichier en .env et remplir les valeurs

# ── Serveur ────────────────────────────────
PORT=3001
BASE_URL=https://votre-domaine.com

# ── Twilio (appels VoIP) ───────────────────
# Créer un compte sur twilio.com
# Console > Account > API keys
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+12015550123
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your_api_secret_here

# ── Wave Money (paiement) ──────────────────
# Créer un compte marchand sur wave.com/business
# Dashboard > Intégrations > API
WAVE_API_KEY=wave_sn_prod_xxxxxxxxxxxxxxxx

# ── Orange Money (paiement) ────────────────
# S'inscrire sur developer.orange.com
# Créer une app et activer "Orange Money Webpay"
ORANGE_CLIENT_ID=your_orange_client_id
ORANGE_CLIENT_SECRET=your_orange_client_secret
ORANGE_MERCHANT_KEY=your_merchant_key
